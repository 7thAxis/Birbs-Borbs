{
    "Format": "2.0.0",
    "ConfigSchema": {

    "Wild Corvids": {
            "AllowValues": "true, false",
            "Default": true,
            "AllowBlank": false,
            "Description":"Allows random corvids to spawn in the overworld.",
            "Section": "Graphics"
    },
    "Egg Accessibility Mode": {
            "AllowValues": "true, false",
            "Default": false,
            "AllowBlank": false,
            "Description":"Adds bright borders around eggs, making them a bit easier to find!",
            "Section": "Graphics"
    },
    "Vanilla Crow Retexture": {
            "AllowValues": "true, false",
            "Default": true,
            "AllowBlank": false,
            "Description":"Replaces vanilla crow textures with ones in this mod's style.",
            "Section": "Graphics"
    },
    "Exclude Items From Perfection": {
            "AllowValues": "true, false",
            "Default": false,
            "AllowBlank": false,
            "Description":"Excludes items from perfection. Golden items are always excluded regardless of this toggle.",
            "Section": "Gameplay"
    },
    "Dungeon Audio Changes": {
            "AllowValues": "true, false",
            "Default": true,
            "AllowBlank": false,
            "Description":"Replaces monster sound effects with crow caws when in The Murder Below dungeon. Disable if you experience a significant lag spike when entering/exiting the dungeon. Hardware dependant.",
            "Section": "Other"
    }
},
    "DynamicTokens": [
        { "Name": "DungeonStage", "Value": "0" }, 
        {
            "Name": "DungeonStage", "Value": 1,
            "When": { "HasFlag": "CnC_Reached_MineLevel_100" }
        },  
        {
            "Name": "DungeonStage", "Value": 2,
            "When": { "HasFlag": "HasSkullKey, CnC_Reached_MineLevel_120" }
        }, 
        {
            "Name": "DungeonStage", "Value": 3,
            "When": { "HasFlag": "galaxySword, HasUnlockedSkullDoor" }
        }, 
        {
            "Name": "DungeonStage", "Value": 4,
            "When": { "HasFlag": "CnC_Reached_SkullLevel_25" }
        }, 
        {
            "Name": "DungeonStage", "Value": 5,
            "When": { "HasFlag": "CnC_Reached_SkullLevel_50, reachedCaldera" }
        }, 
        {
            "Name": "DungeonStage", "Value": 6,
            "When": { "HasFlag": "CnC_Reached_SkullLevel_75, CnC_QiChallenge9_Received" }
        }, 
        {
            "Name": "DungeonStage", "Value": 7,
            "When": { "HasFlag": "reachedBottomOfHardMines, CnC_Reached_SkullLevel_100, CnC_Has_Infinity_Blade, CnC_Has_Combat_Mastery" }
        }, 
        {
            "Name": "DungeonStage", "Value": 8,
