{
    "Format": "2.0.0",
    "ConfigSchema": {
        "Ostrich Incubator Changes": {
            "AllowValues": "true, false",
            "Default": true,
            "AllowBlank": false,
            "Description":"Changes the name and description of the Ostrich Incubator to reference general large animals.",
            "Section": "Gameplay"
    },
    "Early Ostrich Incubator": {
            "AllowValues": "true, false",
            "Default": true,
            "AllowBlank": false,
            "Description":"Allows purchase of the Ostrich Incubator from Marnie's Shop after purchasing a barn.",
            "Section": "Gameplay"
    },
    "Exclude Items From Perfection": {
            "AllowValues": "true, false",
            "Default": false,
            "AllowBlank": false,
            "Description":"Excludes items from perfection. Golden items are always excluded regardless of this toggle.",
            "Section": "Gameplay"
    },
    "Craftable Owl Paintings": {
            "AllowValues": "true, false",
            "Default": true,
            "AllowBlank": false,
            "Description":"Allows you to craft owl paintings. If the visual clutter due to the game's crafting item display limitations is bothersome, disable this and purchase from them Marnie instead.",
            "Section": "Gameplay"
    },
    "Over-world Owls": {
            "AllowValues": "true, false",
            "Default": true,
            "AllowBlank": false,
            "Description":"Allows random owls to spawn in the overworld.",
            "Section": "Graphics"
    },
    "Full Boggy Mode": {
            "AllowValues": "true, false",
            "Default": false,
            "AllowBlank": false,
            "Description":"INCOMPLETE. Will change all assets to more ~boggy~ colors. Currently just changes the frames of the owl paintings.",
            "Section": "Graphics"
    },
    "Egg Accessibility Mode": {
            "AllowValues": "true, false",
            "Default": false,
            "AllowBlank": false,
            "Description":"Adds bright borders around eggs, making them a bit easier to find!",
            "Section": "Graphics"
    }
},
